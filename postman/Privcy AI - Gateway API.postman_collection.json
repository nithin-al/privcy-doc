                        "item": [
                                {
                                        "name": "Google Sign In",
                                        "event": [
                                                {
                                                        "listen": "test",
                                                        "script": {
                                                                "exec": [
                                                                        "if (pm.response.code === 200) {",
                                                                        "    const response = pm.response.json();",
                                                                        "    if (response.data && response.data.tokens) {",
                                                                        "        if (response.data.tokens.accessToken) {",
                                                                        "            pm.environment.set('access_token', response.data.tokens.accessToken);",
                                                                        "            console.log('Access token saved to environment');",
                                                                        "        }",
                                                                        "        if (response.data.tokens.refreshToken) {",
                                                                        "            pm.environment.set('refresh_token', response.data.tokens.refreshToken);",
                                                                        "            console.log('Refresh token saved to environment');",
                                                                        "        }",
                                                                        "    }",
                                                                        "    if (response.data && response.data.sync_status && response.data.sync_status.task_id) {",
                                                                        "        pm.environment.set('task_id', response.data.sync_status.task_id);",
                                                                        "        console.log('Task ID saved to environment');",
                                                                        "    }",
                                                                        "}"
                                                                ],
                                                                "type": "text/javascript"
                                                        }
                                                }
                                        ],
                                        "request": {
                                                "auth": {
                                                        "type": "noauth"
                                                },
                                                "method": "POST",
                                                "header": [
                                                        {
                                                                "key": "Content-Type",
                                                                "value": "application/json"
                                                        }
                                                ],
                                                "body": {
                                                        "mode": "raw",
                                                        "raw": "{\n  \"serverAuthCode\": \"4/0ASc3gC338aKPBHzY__p1XPR6TyPIab8QLHw8EmZlDDgZKdNrxl1doUQYnVyIiDdjAVIT_g\",\n  \"metadata\": {\n    \"ip_address\": \"127.0.0.1\",\n    \"user_agent\": \"Postman\",\n    \"device_type\": \"desktop\",\n    \"device_name\": \"test-device\",\n    \"timestamp\": \"2025-11-18T22:07:00Z\"\n  }\n}"
                                                },
                                                "url": {
